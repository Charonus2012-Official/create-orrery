{
  "sea_level": 0,
  "disable_mob_generation": true,
  "aquifers_enabled": false,
  "ore_veins_enabled": false,
  "legacy_random_source": false,
  "spawn_target": [],
  "default_block": { "Name": "orrery:pluto_stone" },
  "default_fluid": { "Name": "minecraft:air" },
  "noise": {
    "height": 256,
    "min_y": 0,
    "size_horizontal": 1,
    "size_vertical": 2
  },
  "noise_router": {
    "barrier": 0,
    "fluid_level_floodedness": 0,
    "fluid_level_spread": 0,
    "lava": 0,
    "temperature": 0,
    "vegetation": 0,
    "continents": {
      "type": "minecraft:noise",
      "noise": "minecraft:continentalness",
      "xz_scale": 0.12,
      "y_scale": 0.0
    },
    "erosion": {
      "type": "minecraft:noise",
      "noise": "minecraft:erosion",
      "xz_scale": 0.18,
      "y_scale": 0.0
    },
    "depth": {
      "type": "minecraft:y_clamped_gradient",
      "from_y": 0,
      "to_y": 144,
      "from_value": 1.0,
      "to_value": -1.0
    },
    "ridges": {
      "type": "minecraft:noise",
      "noise": "minecraft:ridge",
      "xz_scale": 0.2,
      "y_scale": 0.0
    },
    "initial_density_without_jaggedness": {
      "type": "minecraft:add",
      "argument1": {
        "type": "minecraft:y_clamped_gradient",
        "from_y": 0,
        "to_y": 144,
        "from_value": 1.0,
        "to_value": -1.0
      },
      "argument2": {
        "type": "minecraft:mul",
        "argument1": {
          "type": "minecraft:noise",
          "noise": "minecraft:continentalness",
          "xz_scale": 0.12,
          "y_scale": 0.0
        },
        "argument2": 0.45
      }
    },
    "final_density": {
      "type": "minecraft:add",
      "argument1": {
        "type": "minecraft:add",
        "argument1": {
          "type": "minecraft:y_clamped_gradient",
          "from_y": 0,
          "to_y": 144,
          "from_value": 1.0,
          "to_value": -1.0
        },
        "argument2": {
          "type": "minecraft:mul",
          "argument1": {
            "type": "minecraft:noise",
            "noise": "minecraft:continentalness",
            "xz_scale": 0.12,
            "y_scale": 0.0
          },
          "argument2": 0.45
        }
      },
      "argument2": {
        "type": "minecraft:mul",
        "argument1": {
          "type": "minecraft:noise",
          "noise": "minecraft:ridge",
          "xz_scale": 0.2,
          "y_scale": 0.0
        },
        "argument2": 0.18
      }
    },
    "vein_toggle": 0,
    "vein_rareness": 0,
    "vein_gap": 0,
    "vein_ridged": 0
  },
  "surface_rule": {
    "type": "minecraft:sequence",
    "sequence": [
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:vertical_gradient",
          "random_name": "minecraft:bedrock_floor",
          "true_at_and_below": {
            "absolute": 0
          },
          "false_at_and_above": {
            "absolute": 5
          }
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": { "Name": "minecraft:bedrock" }
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": { "type": "minecraft:above_preliminary_surface" },
        "then_run": {
          "type": "minecraft:sequence",
          "sequence": [
            {
              "type": "minecraft:condition",
              "if_true": {
                "type": "minecraft:stone_depth",
                "offset": 0,
                "surface_type": "floor",
                "add_surface_depth": false,
                "secondary_depth_range": 0
              },
              "then_run": {
                "type": "minecraft:sequence",
                "sequence": [
                  {
                    "type": "minecraft:condition",
                    "if_true": {
                      "type": "minecraft:noise_threshold",
                      "noise": "minecraft:surface",
                      "min_threshold": -0.4,
                      "max_threshold": 100.0
                    },
                    "then_run": {
                      "type": "minecraft:sequence",
                      "sequence": [
                        {
                          "type": "minecraft:condition",
                          "if_true": {
                            "type": "minecraft:noise_threshold",
                            "noise": "minecraft:surface_swamp",
                            "min_threshold": 0.0,
                            "max_threshold": 100.0
                          },
                          "then_run": {
                            "type": "minecraft:block",
                            "result_state": { "Name": "minecraft:ice" }
                          }
                        },
                        {
                          "type": "minecraft:block",
                          "result_state": { "Name": "minecraft:snow_block" }
                        }
                      ]
                    }
                  },
                  {
                    "type": "minecraft:block",
                    "result_state": { "Name": "orrery:pluto_sand" }
                  }
                ]
              }
            },
            {
              "type": "minecraft:condition",
              "if_true": {
                "type": "minecraft:stone_depth",
                "offset": 4,
                "surface_type": "floor",
                "add_surface_depth": true,
                "secondary_depth_range": 0
              },
              "then_run": {
                "type": "minecraft:block",
                "result_state": { "Name": "orrery:pluto_sand" }
              }
            }
          ]
        }
      },
      {
        "type": "minecraft:block",
        "result_state": { "Name": "orrery:pluto_stone" }
      }
    ]
  }
}
